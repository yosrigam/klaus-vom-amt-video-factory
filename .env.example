APP_NAME="Klaus vom Amt Video Factory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://klaus-vom-amt-video-factory.test
APP_PUBLIC_VIDEO_BASE_URL=http://klaus-vom-amt-video-factory.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_ORGANIZATION=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Use chatgpt-image-latest if gpt-image-* returns 403 until org verification completes
OPENAI_IMAGE_MODEL=chatgpt-image-latest

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
# TikTok developer portal — use your production APP_URL:
# Terms of Service: {APP_URL}/terms-of-service
# Privacy Policy: {APP_URL}/privacy-policy

KLAUS_CONTACT_EMAIL=makarovirso@gmail.com
# KLAUS_TERMS_URL=
# KLAUS_PRIVACY_URL=

FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# Background music pool is configured in config/klaus.php (background_music_paths).
KLAUS_BACKGROUND_MUSIC_VOLUME=0.10
KLAUS_NARRATION_VOLUME=1.10
KLAUS_NARRATION_STYLE=awkward
KLAUS_SCRIPT_GERMAN_INTRO="Klaus vom Amt hier."
KLAUS_SCRIPT_GERMAN_OUTRO="Der Vorgang ist abgeschlossen.

Auf Wiedersehen."
# Full path if edge-tts is not on PATH (e.g. pip3 install --user edge-tts)
EDGE_TTS_PATH=/Users/yosrigam/Library/Python/3.9/bin/edge-tts
EDGE_TTS_VOICE=en-GB-ThomasNeural
EDGE_TTS_INTRO_VOICE=de-DE-ConradNeural
EDGE_TTS_INTRO_PHRASE_COUNT=1
EDGE_TTS_CHUNK_SENTENCES=true
EDGE_TTS_MERGE_SHORT_PHRASES=false
EDGE_TTS_SENTENCE_PAUSE=0.50
EDGE_TTS_SHORT_PHRASE_PAUSE=0.35
EDGE_TTS_BOOKEND_PAUSE=1.0
EDGE_TTS_PRE_PUNCHLINE_PAUSE=0.45
EDGE_TTS_PUNCHLINE_PAUSE=0.95
EDGE_TTS_PARAGRAPH_BREAK_PAUSE=1.0
EDGE_TTS_BEAT_PAUSE=1.0
EDGE_TTS_BEAT_BEAT=1.40
EDGE_TTS_BEAT_LONG_BEAT=2.0
EDGE_TTS_DRAMATIC_PAUSE_MULTIPLIER=1.0
# Added to every delivery-style rate (e.g. -8% makes NeutralObservation ~12% slower than its base).
EDGE_TTS_RATE=-8%
EDGE_TTS_PAUSE_MULTIPLIER=1.0
EDGE_TTS_TRIM_TRAILING_SILENCE=false
EDGE_TTS_PITCH=-3Hz
EDGE_TTS_VOLUME=+0%
EDGE_TTS_LOUDNORM_ENABLED=true

# Optional ElevenLabs narrator (much higher quality than edge-tts)
# KLAUS_TTS_DRIVER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_INTRO_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2

VITE_APP_NAME="${APP_NAME}"
